<Window x:Class="VittaTest.Views.PaymentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VittaTest.Views"
        mc:Ignorable="d"
        Title="Платежи" Height="450" Width="800">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Все платежи" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Payments}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="None">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID платежа" Width="Auto">
                    <DataGridTextColumn.Binding>
                        <Binding Path="PaymentId" StringFormat="{}{0:D}"/>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="№ Заказа" Binding="{Binding OrderNumber}" Width="Auto"/>
                <DataGridTextColumn Header="№ Поступления" Binding="{Binding InflowNumber}" Width="Auto"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding PaymentAmount, StringFormat=N2}" Width="Auto"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding PaymentDate, StringFormat=dd.MM.yyyy HH:mm}" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
