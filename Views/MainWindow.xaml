<Window x:Class="VittaTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VittaTest" 
        xmlns:viewmodels="clr-namespace:VittaTest.ViewModels" 
        d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
        mc:Ignorable="d"
        Title="Учёт заказов и платежей" 
        Height="520" 
        Width="620"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Выбор заказа -->
        <GroupBox Header="Заказ" Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="10">
                <Button Content="Выбрать заказ" 
                        Command="{Binding OpenSelectOrderWindowCommand}"
                        Padding="15,8" Width="160"/>

                <Button Content="Очистить" 
                        Command="{Binding ClearOrderCommand}"
                        Margin="10,0,0,0" Padding="12,8"/>
            </StackPanel>
        </GroupBox>

        <!-- Выбранный заказ -->
        <GroupBox Header="Выбранный заказ" Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Margin="12" FontSize="13" TextWrapping="Wrap">
                <Run Text="{Binding SelectedOrder.OrderNumber, TargetNullValue='—', FallbackValue='—'}" />
                <Run Text="{Binding SelectedOrder.OrderDate, StringFormat=' от {0:dd.MM.yyyy}', TargetNullValue=''}" />
                <Run Text="{Binding SelectedOrder.Amount, StringFormat=' — {0:N2} руб.', TargetNullValue=''}" />
                <Run Text="{Binding SelectedOrder.PaidAmount, StringFormat=' (Оплачено: {0:N2})', TargetNullValue=''}" />
            </TextBlock>
        </GroupBox>

        <!-- Выбор поступления -->
        <GroupBox Header="Поступление денежных средств" Grid.Row="2" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="10">
                <Button Content="Выбрать приход" 
                        Command="{Binding OpenSelectInflowWindowCommand}"
                        Padding="15,8" Width="160"/>

                <Button Content="Очистить" 
                        Command="{Binding ClearInflowCommand}"
                        Margin="10,0,0,0" Padding="12,8"/>
            </StackPanel>
        </GroupBox>

        <!-- Выбранное поступление -->
        <GroupBox Header="Выбранное поступление" Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Margin="12" FontSize="13">
                <Run Text="{Binding SelectedInflow.InflowNumber, TargetNullValue='—', FallbackValue='—'}" />
                <Run Text="{Binding SelectedInflow.InflowDate, StringFormat=' от {0:dd.MM.yyyy}', TargetNullValue=''}" />
                <Run Text="{Binding SelectedInflow.Remaining, StringFormat=' — Остаток: {0:N2} руб.', TargetNullValue=''}" />   
            </TextBlock>
        </GroupBox>

        <!-- Действия -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="Просмотреть платежи" 
                    Command="{Binding OpenPaymentsWindowCommand}"
                    Padding="15,10" Width="160" Margin="0,0,15,0"/>

            <Button Content="Выполнить платёж" 
                    Command="{Binding MakePaymentCommand}"
                    Padding="15,10"
                    IsEnabled="{Binding CanMakePayment}"/>
        </StackPanel>

        <!-- Поле суммы платежа -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,20,0,0">
            <TextBlock Text="Сумма платежа:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
            <TextBox Text="{Binding PaymentAmount, UpdateSourceTrigger=PropertyChanged}" 
                     Width="160" Height="32" FontSize="14"/>
        </StackPanel>
    </Grid>
</Window>
