<Window x:Class="VittaTest.Views.SelectCashInflowWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VittaTest.Views"
        mc:Ignorable="d"
        xmlns:controls="clr-namespace:VittaTest.Controls" 
        xmlns:dialogs="clr-namespace:VittaTest.ViewModels.Dialogs" 
        d:DataContext="{d:DesignInstance Type=dialogs:SelectCashInflowViewModel}"
        Title="Выбор прихода" Height="580" Width="720"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- The search box is inside the control, not here -->
        <controls:FilterableDataGridControl 
            ItemsView="{Binding CashInflowsView}"
            SelectedItem="{Binding SelectedInflow, Mode=TwoWay}"
            SearchText="{Binding SearchText}"
            SearchColumnPath="{Binding SearchColumnPath}">

            <!-- Define columns for this view -->
            <DataGridTextColumn Header="Номер прихода"
                                Binding="{Binding InflowNumber}" Width="Auto"/>
            <DataGridTextColumn Header="Остаток"
                                Binding="{Binding Remaining, StringFormat=N2}" Width="Auto"/>
            <DataGridTextColumn Header="Сумма прихода"
                                Binding="{Binding Amount}" Width="Auto"/>
            <DataGridTextColumn Header="Дата"
                                Binding="{Binding InflowDate, StringFormat=dd.MM.yyyy}" Width="Auto"/>
        </controls:FilterableDataGridControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Выбрать" Command="{Binding SelectCommand}"
                    Padding="20,8" Width="120" IsDefault="True"/>
            <Button Content="Отмена" Command="{Binding CancelCommand}"
                    Padding="20,8" Width="120" Margin="10,0,0,0" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
